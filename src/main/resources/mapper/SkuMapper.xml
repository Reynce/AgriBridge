<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.reyn.mapper.SkuMapper">

    <select id="selectByIds" resultType="com.reyn.objects.entity.Sku">
        SELECT *
        FROM sku
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
    <select id="getSpecificationByIdString" resultType="java.lang.String">
        select specification from sku where id = #{id}
    </select>

</mapper>
