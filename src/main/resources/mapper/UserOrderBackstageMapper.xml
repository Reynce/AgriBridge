<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.reyn.mapper.UserOrderBackstageMapper">
    
    <resultMap type="com.reyn.objects.entity.UserOrder" id="UserOrderResult">
        <result property="id"    column="id"    />
        <result property="orderNo"    column="order_no"    />
        <result property="buyerId"    column="buyer_id"    />
        <result property="totalPrice"    column="total_price"    />
        <result property="orderStatus"    column="order_status"    />
        <result property="timeoutAt"    column="timeout_at"    />
        <result property="paymentStatus"    column="payment_status"    />
        <result property="shippingAddress"    column="shipping_address"    />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
    </resultMap>

    <resultMap id="UserOrderOrderDetailResult" type="com.reyn.objects.entity.UserOrder" extends="UserOrderResult">
        <collection property="orderDetailList" ofType="com.reyn.objects.entity.OrderDetail" column="id" select="selectOrderDetailList" />
    </resultMap>

    <resultMap type="com.reyn.objects.entity.OrderDetail" id="OrderDetailResult">
        <result property="id"    column="id"    />
        <result property="orderId"    column="order_id"    />
        <result property="skuId"    column="sku_id"    />
        <result property="sallerId"    column="saller_id"    />
        <result property="productTitle"    column="product_title"    />
        <result property="skuSpecification"    column="sku_specification"    />
        <result property="price"    column="price"    />
        <result property="quantity"    column="quantity"    />
        <result property="productMainImage"    column="product_main_image"    />
        <result property="shippedStatus"    column="shipped_status"    />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
    </resultMap>

    <sql id="selectUserOrderVo">
        select id, order_no, buyer_id, total_price, order_status, timeout_at, payment_status, shipping_address, created_at, updated_at from user_order
    </sql>

    <select id="selectUserOrderList" parameterType="com.reyn.objects.entity.UserOrder" resultType="com.reyn.objects.entity.UserOrder">
        <include refid="selectUserOrderVo"/>
        <where>  
            <if test="orderNo != null  and orderNo != ''"> and order_no = #{orderNo}</if>
            <if test="buyerId != null "> and buyer_id = #{buyerId}</if>
            <if test="totalPrice != null "> and total_price = #{totalPrice}</if>
            <if test="orderStatus != null "> and order_status = #{orderStatus}</if>
            <if test="timeoutAt != null "> and timeout_at = #{timeoutAt}</if>
            <if test="paymentStatus != null "> and payment_status = #{paymentStatus}</if>
            <if test="shippingAddress != null  and shippingAddress != ''"> and shipping_address = #{shippingAddress}</if>
            <if test="createdAt != null "> and created_at = #{createdAt}</if>
            <if test="updatedAt != null "> and updated_at = #{updatedAt}</if>
        </where>
    </select>

    <select id="selectUserOrderById" parameterType="Long" resultMap="UserOrderOrderDetailResult">
        select id, order_no, buyer_id, total_price, order_status, timeout_at, payment_status, shipping_address, created_at, updated_at
        from user_order
        where id = #{id}
    </select>

    <select id="selectOrderDetailList" resultMap="OrderDetailResult">
        select id, order_id, sku_id, saller_id, product_title, sku_specification, price, quantity, product_main_image, shipped_status, created_at, updated_at
        from order_detail
        where order_id = #{order_id}
    </select>

    <insert id="insertUserOrder" parameterType="com.reyn.objects.entity.UserOrder" useGeneratedKeys="true" keyProperty="id">
        insert into user_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderNo != null">order_no,</if>
            <if test="buyerId != null">buyer_id,</if>
            <if test="totalPrice != null">total_price,</if>
            <if test="orderStatus != null">order_status,</if>
            <if test="timeoutAt != null">timeout_at,</if>
            <if test="paymentStatus != null">payment_status,</if>
            <if test="shippingAddress != null and shippingAddress != ''">shipping_address,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderNo != null">#{orderNo},</if>
            <if test="buyerId != null">#{buyerId},</if>
            <if test="totalPrice != null">#{totalPrice},</if>
            <if test="orderStatus != null">#{orderStatus},</if>
            <if test="timeoutAt != null">#{timeoutAt},</if>
            <if test="paymentStatus != null">#{paymentStatus},</if>
            <if test="shippingAddress != null and shippingAddress != ''">#{shippingAddress},</if>
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
        </trim>
    </insert>

    <update id="updateUserOrder" parameterType="com.reyn.objects.entity.UserOrder">
        update user_order
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderNo != null">order_no = #{orderNo},</if>
            <if test="buyerId != null">buyer_id = #{buyerId},</if>
            <if test="totalPrice != null">total_price = #{totalPrice},</if>
            <if test="orderStatus != null">order_status = #{orderStatus},</if>
<!--            <if test="timeoutAt != null">timeout_at = #{timeoutAt},</if>-->
            <if test="paymentStatus != null">payment_status = #{paymentStatus},</if>
            <if test="shippingAddress != null and shippingAddress != ''">shipping_address = #{shippingAddress},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteUserOrderById" parameterType="Long">
        delete from user_order where id = #{id}
    </delete>

    <delete id="deleteUserOrderByIds" parameterType="String">
        delete from user_order where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteOrderDetailByOrderIds" parameterType="String">
        delete from order_detail where order_id in
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>

    <delete id="deleteOrderDetailByOrderId" parameterType="Long">
        delete from order_detail where order_id = #{orderId}
    </delete>

    <insert id="batchOrderDetail">
        insert into order_detail( id, order_id, sku_id, saller_id, product_title, sku_specification, price, quantity, product_main_image, shipped_status, created_at, updated_at) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.id}, #{item.orderId}, #{item.skuId}, #{item.sallerId}, #{item.productTitle}, #{item.skuSpecification}, #{item.price}, #{item.quantity}, #{item.productMainImage}, #{item.shippedStatus}, #{item.createdAt}, #{item.updatedAt})
        </foreach>
    </insert>
</mapper>